# Copy to .env for local development (loaded by `npm run dev`).
# On Fargate, set these in the task definition instead.
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
# Service identifier attached to every log line (a dimension for dashboards).
SERVICE_NAME=express-fargate-service
SHUTDOWN_TIMEOUT_MS=10000

# Comma-separated browser origins allowed to call the API (the MSAL SPA).
# Empty/unset denies all cross-origin requests.
CORS_ORIGINS=http://localhost:5173

# Max accepted JSON request body (anything larger → 413). Default 100kb.
# JSON_BODY_LIMIT=100kb

# Keep-alive must exceed the ALB idle timeout (default 60s) to avoid 502s.
# Defaults (65000 / 66000) are sane; only override to match a custom ALB idle timeout.
# KEEP_ALIVE_TIMEOUT_MS=65000
# HEADERS_TIMEOUT_MS=66000

# --- Microsoft Entra ID (Azure AD) JWT auth ---
# From your API's App Registration in the Entra admin center.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Expected `aud` claim in incoming access tokens. Commonly the same as
# AZURE_CLIENT_ID, or the Application ID URI (api://<client-id>).
# Defaults to AZURE_CLIENT_ID if left unset.
AZURE_AD_AUDIENCE=api://00000000-0000-0000-0000-000000000000

# Optional overrides (sensible v2.0 defaults are derived from the tenant):
# Sovereign clouds use a different instance host (e.g. login.microsoftonline.us).
# AZURE_AD_INSTANCE=https://login.microsoftonline.com
# Override the issuer if your app still issues v1.0 tokens
# (accessTokenAcceptedVersion != 2): https://sts.windows.net/<tenant-id>/
# AZURE_AD_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# AZURE_AD_JWKS_URI=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
