{
  "name": "express-fargate-service",
  "version": "1.0.0",
  "description": "KISS Express.js JSON API, container-ready for ECR/ECS Fargate",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jose": "^6.0.0",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.5",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.6.0",
    "supertest": "^7.1.1",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  }
}
